{
    "family": "rag-qa-chatbot23-task",
    "networkMode": "awsvpc",
    "executionRoleArn": "arn:aws:iam::250789929878:role/ecs-full-acess",
    "containerDefinitions": [
        {
            "name": "rag-qa-container",
            "image": "IMAGE_URI_PLACEHOLDER",
            "portMappings": [
                {
                    "containerPort": 8000,
                    "protocol": "tcp"
                }
            ],
            "essential": true,
            "environment": [
                {
                    "name": "OPENAI_API_KEY",
                    "value": "PLACEHOLDER"
                },
                {
                    "name": "QDRANT_URL",
                    "value": "PLACEHOLDER"
                },
                {
                    "name": "QDRANT_API_KEY",
                    "value": "PLACEHOLDER"
                },
                {
                    "name": "LOG_LEVEL",
                    "value": "INFO"
                },
                {
                    "name": "LANGSMITH_TRACING",
                    "value": "true"
                },
                {
                    "name": "LANGSMITH_API_KEY",
                    "value": "PLACEHOLDER"
                },
                {
                    "name": "LANGSMITH_PROJECT",
                    "value": "rag-qa-production"
                },
                {
                    "name": "LANGSMITH_ENDPOINT",
                    "value": "https://eu.api.smith.langchain.com"
                }
            ]
        }
    ],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "1024",
    "memory": "2048"
}